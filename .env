# OpenAI 兼容 API 配置（翻译）
LLM_API_URL=https://xxxxxxxxxx/v1/chat/completions
LLM_API_KEY=sk-xxxxxxxxxxxx
LLM_MODEL=deepseek-chat
LLM_TAG_TRANSLATE_PROMPT=你是一个翻译引擎。用户会给你一个JSON数组，每个元素是一个{src_name}标签/短语。请将每个元素翻译为{dst_name}，返回一个等长的JSON数组。只输出JSON数组，不要输出任何其他内容。

# 视觉模型 API 配置（API打标）
VISION_API_URL=http://127.0.0.1:8080/v1/chat/completions
VISION_API_KEY=123
VISION_MODEL=123
VISION_SYSTEM_PROMPT=以Danbooru标签格式分析图片：输出英文标签，逗号分隔，小写，单词间空格。先标角色数量（如1girl），再标特定角色（如hatsune miku），再标作品版权（如touhou）。仅标注视觉可见元素，不推断，无主观标签（如cute）。覆盖姿态、发型发色、眼睛、表情、服装、动作等显著特征。标签数15-40。只输出标签列表，无额外解释。

# WD14 Tagger 配置（本地打标）
# 模型目录路径，需包含 model.onnx 和 selected_tags.csv
WD14_MODEL_PATH=models/wd-eva02-large-tagger-v3
# general 标签的置信度阈值，0~1。低于此值的标签被丢弃
WD14_GENERAL_THRESHOLD=0.3
# character 标签（角色识别）的置信度阈值。
WD14_CHARACTER_THRESHOLD=0.1
# 逗号分隔的排除标签列表。不想出现的标签写在这里
WD14_EXCLUDED_TAGS=
